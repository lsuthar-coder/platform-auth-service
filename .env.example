# .env.example — copy to .env for local dev. Never commit .env.

DATABASE_URL=postgresql://ADMIN:yourpassword@your-adb-host/ORCL?sslmode=require
REDIS_URL=redis://localhost:6379

# Generate RSA key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the full PEM content here (keep newlines as \n or use multiline)
PRIVATE_KEY_PEM=
PUBLIC_KEY_PEM=

# OpenTelemetry — leave empty to disable tracing locally
OTLP_ENDPOINT=
OTLP_USERNAME=
OTLP_PASSWORD=

SERVICE_NAME=auth-service
PORT=5000
NODE_ENV=development
